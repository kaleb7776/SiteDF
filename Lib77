                    BackgroundColor3 = Color3.new(1, 1, 1),
                    AutoButtonColor = false,
                    ZIndex = 31,
                    Parent = Picker
                })
                
                if HueBar then
                    AddCorner(HueBar, 4)
                    
                    Create("UIGradient", {
                        Rotation = 90,
                        Color = ColorSequence.new({
                            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
                            ColorSequenceKeypoint.new(0.167, Color3.fromRGB(255, 255, 0)),
                            ColorSequenceKeypoint.new(0.333, Color3.fromRGB(0, 255, 0)),
                            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
                            ColorSequenceKeypoint.new(0.667, Color3.fromRGB(0, 0, 255)),
                            ColorSequenceKeypoint.new(0.833, Color3.fromRGB(255, 0, 255)),
                            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
                        }),
                        Parent = HueBar
                    })
                end
                
                local HueCursor = Create("Frame", {
                    Name = "Cursor",
                    Size = UDim2.new(1, 4, 0, 4),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Position = UDim2.new(0.5, 0, h, 0),
                    BackgroundColor3 = Color3.new(1, 1, 1),
                    ZIndex = 32,
                    BorderSizePixel = 0,
                    Parent = HueBar
                })
                
                if HueCursor then
                    AddCorner(HueCursor, 2)
                    AddStroke(HueCursor, Color3.new(0, 0, 0), 1)
                end
                
                local function UpdateColor()
                    color = Color3.fromHSV(h, s, v)
                    if ColorBtn then ColorBtn.BackgroundColor3 = color end
                    if SVMap then SVMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1) end
                    if flag then Library.Flags[flag] = color end
                    pcall(callback, color)
                end
                
                local draggingSV = false
                local draggingHue = false
                
                if SVMap then
                    SVMap.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            draggingSV = true
                        end
                    end)
                end
                
                if HueBar then
                    HueBar.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            draggingHue = true
                        end
                    end)
                end
                
                UserInputService.InputChanged:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                        if draggingSV and SVMap then
                            local rx = math.clamp((input.Position.X - SVMap.AbsolutePosition.X) / SVMap.AbsoluteSize.X, 0, 1)
                            local ry = math.clamp((input.Position.Y - SVMap.AbsolutePosition.Y) / SVMap.AbsoluteSize.Y, 0, 1)
                            s = rx
                            v = 1 - ry
                            if SVCursor then SVCursor.Position = UDim2.new(s, 0, 1 - v, 0) end
                            UpdateColor()
                        elseif draggingHue and HueBar then
                            local ry = math.clamp((input.Position.Y - HueBar.AbsolutePosition.Y) / HueBar.AbsoluteSize.Y, 0, 1)
                            h = ry
                            if HueCursor then HueCursor.Position = UDim2.new(0.5, 0, h, 0) end
                            UpdateColor()
                        end
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        draggingSV = false
                        draggingHue = false
                    end
                end)
                
                if ColorBtn then
                    ColorBtn.MouseButton1Click:Connect(function()
                        open = not open
                        if open then
                            if Picker then Picker.Visible = true end
                            Tween(Picker, 0.2, {Size = UDim2.new(1, 0, 0, 110)})
                            ColorFrame.Size = UDim2.new(1, 0, 0, 146)
                        else
                            Tween(Picker, 0.2, {Size = UDim2.new(1, 0, 0, 0)})
                            task.delay(0.2, function()
                                if Picker then Picker.Visible = false end
                            end)
                            ColorFrame.Size = UDim2.new(1, 0, 0, 32)
                        end
                    end)
                end
                
                if flag then Library.Flags[flag] = color end
                
                local obj = {}
                function obj:Set(col)
                    h, s, v = col:ToHSV()
                    if SVCursor then SVCursor.Position = UDim2.new(s, 0, 1 - v, 0) end
                    if HueCursor then HueCursor.Position = UDim2.new(0.5, 0, h, 0) end
                    UpdateColor()
                end
                function obj:Get()
                    return color
                end
                return obj
            end
            
            return SectionObj
        end
        
        return Tab
    end

    
    return Window
end

return Library
